generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  phone            String   @unique
  name             String?
  email            String?
  password         String?
  isAdmin          Boolean  @default(false)

  planType         String   @default("free")
  aiMode           String   @default("SEM_CADASTRO")
  financialProfile String?
  interestStage    String?  @default("NENHUM")

  messagesToday    Int      @default(0)
  lastMessageDay   String?
  planExpiresAt    String?

  isActive         Boolean  @default(false)

  createdAt        DateTime @default(now())

  contracts        Contract[]
  appointments     Appointment[]
}

model Appointment {
  id          Int      @id @default(autoincrement())
  clientName  String
  phone       String?
  date        String
  time        String
  description String

  userId      Int?
  user        User? @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model BlockedNumber {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  createdAt DateTime @default(now())
}

model Client {
  id               Int      @id @default(autoincrement())

  name             String
  fullName         String?
  cpf              String?
  phone            String   @unique
  password         String?

  serviceType      String
  planType         String   @default("basic")

  contractNumber   String?
  totalValue       Float?
  installments     String?
  contractDate     String?
  firstDueDate     String?

  aiMode           String   @default("SEM_CADASTRO")
  financialProfile String?
  interestStage    String?  @default("NENHUM")

  planExpiresAt    String?

  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())

  products         Product[]
}

model Product {
  id                Int      @id @default(autoincrement())

  clientId          Int
  client            Client   @relation(fields: [clientId], references: [id])

  transactionCode   String   @unique

  type              String
  name              String

  quantity          Float?
  unitPrice         Float?
  totalValue        Float?

  contractDate      DateTime?
  nextDueDate       DateTime?
  endDate           DateTime?

  installments      Int?
  paidInstallments  Int      @default(0)
  installmentValue  Float?

  profitability     String?

  status            String   @default("ATIVO")

  createdAt         DateTime @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())

  phone       String
  value       Float

  category    String
  description String?

  createdAt   DateTime @default(now())
}

model Contract {
  id               Int      @id @default(autoincrement())

  contractNumber   String   @unique

  product          String

  totalValue       Float
  installmentValue Float

  installments     Int

  paidInstallments Int      @default(0)

  pendingBalance   Float

  status           String   @default("ativo")

  userId           Int
  user             User @relation(fields: [userId], references: [id])

  payments         Payment[]

  createdAt        DateTime @default(now())
}

model Payment {
  id          Int      @id @default(autoincrement())

  installment Int
  value       Float

  dueDate     String

  paid        Boolean  @default(false)
  paidAt      String?

  contractId  Int

  contract    Contract @relation(fields: [contractId], references: [id])

  createdAt   DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())

  phone     String
  role      String

  content   String   @db.Text

  createdAt DateTime @default(now())
}

model AdminSettings {
  id           Int      @id @default(autoincrement())

  systemPrompt String   @db.Text

  createdAt    DateTime @default(now())
}
  
model BlockedBot {

  id        Int      @id @default(autoincrement())

  phone     String

  reason    String?

  createdAt DateTime @default(now())
}

