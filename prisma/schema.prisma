generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USER
// =====================================================

model User {

  id              Int      @id @default(autoincrement())

  phone           String   @unique

  name            String?
  cpf             String?
  email           String?
  password        String?

  isAdmin         Boolean  @default(false)

  // =========================
  // PLANOS
  // =========================

  planType        String   @default("free")
  messagesToday   Int      @default(0)
  lastMessageDay  String?
  planExpiresAt   String?
  isActive        Boolean  @default(false)

  createdAt       DateTime @default(now())

  // RELAÇÕES

  contracts       Contract[]
  appointments    Appointment[]
}

// =====================================================
// CONFIG IA
// =====================================================

model AdminSettings {

  id           Int    @id @default(autoincrement())

  systemPrompt String
}

// =====================================================
// HISTÓRICO CHAT
// =====================================================

model Message {

  id        Int      @id @default(autoincrement())

  phone     String
  role      String
  content   String

  createdAt DateTime @default(now())
}

// =====================================================
// NÚMEROS BLOQUEADOS
// =====================================================

model BlockedNumber {

  id        Int      @id @default(autoincrement())

  phone     String   @unique

  createdAt DateTime @default(now())
}

// =====================================================
// CLIENTES
// =====================================================

model Client {

  id          Int      @id @default(autoincrement())

  name        String
  phone       String
  serviceType String

  createdAt   DateTime @default(now())
}

// =====================================================
// GASTOS
// =====================================================

model Expense {

  id          Int      @id @default(autoincrement())

  phone       String
  value       Float
  category    String
  description String?

  createdAt   DateTime @default(now())
}

// =====================================================
// AGENDAMENTOS
// =====================================================

model Appointment {

  id          Int      @id @default(autoincrement())

  clientName  String
  date        String
  time        String
  description String

  userId      Int?

  user        User? @relation(
    fields: [userId],
    references: [id]
  )

  createdAt   DateTime @default(now())
}

// =====================================================
// CONTRATOS
// =====================================================

model Contract {

  id               Int      @id @default(autoincrement())

  contractNumber   String   @unique

  product          String

  totalValue       Float

  installmentValue Float

  installments     Int

  paidInstallments Int      @default(0)

  pendingBalance   Float

  status           String   @default("ativo")

  userId           Int

  user             User @relation(
    fields: [userId],
    references: [id]
  )

  payments         Payment[]

  createdAt        DateTime @default(now())
}

// =====================================================
// PAGAMENTOS
// =====================================================

model Payment {

  id          Int      @id @default(autoincrement())

  installment Int

  value       Float

  dueDate     String

  paid        Boolean  @default(false)

  paidAt      String?

  contractId  Int

  contract    Contract @relation(
    fields: [contractId],
    references: [id]
  )

  createdAt   DateTime @default(now())
}
