generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  createdAt DateTime @default(now())
}
model AdminSettings {
  id           Int    @id @default(autoincrement())
  systemPrompt String
}

model Message {
  id        Int      @id @default(autoincrement())
  phone     String
  role      String
  content   String
  createdAt DateTime @default(now())
}
model BlockedNumber {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  createdAt DateTime @default(now())
}
